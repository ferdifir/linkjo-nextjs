# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Auth
JWT_SECRET="replace-with-long-random-secret"

# Public app URL
NEXT_PUBLIC_PUBLIC_APP_URL="https://linkjo.my.id"
NEXT_PUBLIC_APP_URL=""
PUBLIC_APP_URL=""

# WhatsApp provider selection: fonnte or baileys
WHATSAPP_PROVIDER="fonnte"

# Global system WhatsApp number used for wa.me links and owner verification.
WHATSAPP_NUMBER="628xxxxxxxxxx"
NEXT_PUBLIC_WHATSAPP_NUMBER="628xxxxxxxxxx"

# Fonnte provider. Required when WHATSAPP_PROVIDER=fonnte.
FONNTE_API_KEY=""
FONNTE_WHATSAPP_NUMBER="628xxxxxxxxxx"

# Global inbound webhook guard. Required in production for /api/webhooks/whatsapp.
WA_WEBHOOK_SECRET="replace-with-random-webhook-secret"

# Baileys worker. Local defaults; production should use /var/www/linkjo-next/shared.
WHATSAPP_SHARED_DIR=".data/whatsapp"
WHATSAPP_BAILEYS_AUTH_DIR=".data/whatsapp/baileys-auth"
WHATSAPP_STATUS_PATH=".data/whatsapp/whatsapp-status.json"
WHATSAPP_OUTBOX_POLL_MS="2000"
WHATSAPP_OUTBOX_BATCH_SIZE="10"
BAILEYS_LOG_LEVEL="silent"

# AI assistant. Optional; deterministic fallback still works without this.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"

# Logging
LOG_LEVEL="info"

# E2E/test-only toggles. Do not enable in production.
E2E_TEST_MODE="0"
E2E_SKIP_NOTIFICATIONS="0"
